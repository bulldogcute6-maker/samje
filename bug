            stockLabel.Parent = row
            
            if offer.Image and offer.Image ~= "" then
                local imgLabel = Instance.new("ImageLabel")
                imgLabel.Size = UDim2.fromOffset(36, 36)
                imgLabel.Position = UDim2.new(1, -46, 0, 12)
                imgLabel.BackgroundTransparency = 1
                imgLabel.Image = offer.Image
                imgLabel.ScaleType = Enum.ScaleType.Fit
                imgLabel.Parent = row
                local imgCorner = Instance.new("UICorner")
                imgCorner.CornerRadius = UDim.new(0, 4)
                imgCorner.Parent = imgLabel
            end
            
            local buyButton = Instance.new("TextButton")
            buyButton.Size = UDim2.new(0, 60, 0, 28)
            buyButton.Position = UDim2.new(1, -110, 0, 16)
            buyButton.Text = stock > 0 and "Buy" or "Sold"
            buyButton.TextSize = 12
            buyButton.Font = Enum.Font.GothamBold
            buyButton.AutoButtonColor = stock > 0
            buyButton.BackgroundColor3 = stock > 0 and Color3.fromRGB(59, 130, 246) or Color3.fromRGB(60, 60, 60)
            buyButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            buyButton.Parent = row
            
            local buyCorner = Instance.new("UICorner")
            buyCorner.CornerRadius = UDim.new(0, 4)
            buyCorner.Parent = buyButton
            
            if stock > 0 then
                buyButton.MouseButton1Click:Connect(function() buyMerchantItem(offer.Id) end)
            end
            
            local autoToggle = Instance.new("TextButton")
            autoToggle.Size = UDim2.new(0, 30, 0, 28)
            autoToggle.Position = UDim2.new(1, -44, 0, 16)
            local isAuto = isMerchantAutoBuy(offer.Id)
            autoToggle.Text = isAuto and "★" or "☆"
            autoToggle.TextSize = 16
            autoToggle.Font = Enum.Font.GothamBold
            autoToggle.AutoButtonColor = false
            autoToggle.BackgroundColor3 = isAuto and Color3.fromRGB(232, 45, 67) or Color3.fromRGB(40, 40, 50)
            autoToggle.TextColor3 = isAuto and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(148, 163, 184)
            autoToggle.Parent = row
            
            local autoCorner = Instance.new("UICorner")
            autoCorner.CornerRadius = UDim.new(0, 4)
            autoCorner.Parent = autoToggle
            
            autoToggle.MouseButton1Click:Connect(function()
                local newState = toggleMerchantAutoBuy(offer.Id)
                autoToggle.Text = newState and "★" or "☆"
                autoToggle.BackgroundColor3 = newState and Color3.fromRGB(232, 45, 67) or Color3.fromRGB(40, 40, 50)
                autoToggle.TextColor3 = newState and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(148, 163, 184)
            end)
        end
    end
end

local function updateMerchantTimer()
    local now = os.time()
    local timerText, statusText = "", ""
    if merchantState.Visible then
        statusText = "🟢 Merchant: Open"
        if merchantState.ActiveEndsAt > 0 and now < merchantState.ActiveEndsAt then
            timerText = "⏳ Leaves in: " .. formatMerchantTime(merchantState.ActiveEndsAt - now)
        elseif merchantState.NextArrivalAt > 0 and now < merchantState.NextArrivalAt then
            timerText = "⏳ Next arrival in: " .. formatMerchantTime(merchantState.NextArrivalAt - now)
        else
            timerText = "❌ Merchant unavailable"
        end
    else
        statusText = "🔴 Merchant: Closed"
        if merchantState.NextArrivalAt > 0 and now < merchantState.NextArrivalAt then
            timerText = "⏳ Arrives in: " .. formatMerchantTime(merchantState.NextArrivalAt - now)
        else
            timerText = "⏳ No arrival time set"
        end
    end
    merchantStatusLabel:SetText(statusText)
    merchantTimerLabel:SetText(timerText)
end

task.spawn(function()
    while true do
        task.wait(1)
        pcall(function()
            updateMerchantTimer()
            if merchantState.Visible then renderMerchantItems() end
        end)
    end
end)

local oldApply = applyMerchantData
applyMerchantData = function(data, isInitial)
    oldApply(data, isInitial)
    if merchantState.Visible then
        renderMerchantItems()
        updateMerchantTimer()
    end
end

if merchantState.AutoBuyEnabled then startMerchantAutoBuy() end
if antiAfkEnabled then startAntiAfk() end

ThemeManager:ApplyToTab(MainTab)
ThemeManager:ApplyToTab(MerchantTab)
SaveManager:BuildConfigSection(MainTab)
SaveManager:BuildConfigSection(MerchantTab)

pcall(function() ThemeManager:LoadDefault() end)
pcall(function() SaveManager:LoadAutoloadConfig() end)

Library:OnUnload(function()
    if merchantState.AutoBuyLoop then task.cancel(merchantState.AutoBuyLoop) end
    saveConfig()
end)

