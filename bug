local function startAntiAfk()
    if antiAfkLoop then task.cancel(antiAfkLoop) end
    antiAfkLoop = task.spawn(function()
        while antiAfkEnabled do
            pcall(function()
                local x = math.random(-1, 1)
                local y = math.random(-1, 1)
                if x == 0 and y == 0 then x = 1 end
                UserInputService:SetMouseDelta(Vector2.new(x, y))
            end)
            task.wait(60)
        end
    end)
end

local function stopAntiAfk()
    if antiAfkLoop then task.cancel(antiAfkLoop); antiAfkLoop = nil end
end

local function isPlayerInShop(shop)
    local char = LP.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    if root:IsDescendantOf(shop) then return true end
    
    local ok, cf, size = pcall(function() return shop:GetBoundingBox() end)
    if ok and cf and size then
        local localPos = cf:PointToObjectSpace(root.Position)
        local half = size/2
        if math.abs(localPos.X) <= half.X and math.abs(localPos.Y) <= half.Y and math.abs(localPos.Z) <= half.Z then
            return true
        end
    end
    return false
end

local function getPlayerShop()
    local bases = Workspace:FindFirstChild("Bases")
    if not bases then return nil end
    for _, shop in ipairs(bases:GetChildren()) do
        if shop:IsA("Model") and shop.Name == "Shop" then
            local occupied = shop:GetAttribute("Occupied")
            if occupied then
                local owner = shop:GetAttribute("Owner") or shop:GetAttribute("OwnerUserId")
                if owner and (owner == LP.Name or tostring(owner) == tostring(LP.UserId)) then
                    if isPlayerInShop(shop) then return shop end
                end
            end
        end
    end
    return nil
end

local function equipWalis()
    local char = LP.Character
    if not char then return false end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return false end
    
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name == "Walis" or tool.Name:lower():match("walis")) then 
            return true 
        end
    end
    
    local backpack = LP:FindFirstChildOfClass("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and (tool.Name == "Walis" or tool.Name:lower():match("walis")) then
                humanoid:EquipTool(tool)
                task.wait(0.2)
                return true
            end
        end
    end
    return false
end

local function cleanMesses(shop)
    local cleaningSystem = shop:FindFirstChild("CleaningSystem")
    if not cleaningSystem then return end
    local activeMesses = cleaningSystem:FindFirstChild("ActiveMesses")
    if not activeMesses then return end
    
    for _, mess in ipairs(activeMesses:GetChildren()) do
        if mess:IsA("Model") and mess.Name:match("Mess") then
            local prompt = mess:FindFirstChild("CleanPrompt")
            if prompt and prompt:IsA("ProximityPrompt") then
                local oldHold = prompt.HoldDuration
                prompt.HoldDuration = 0
                pcall(function() fireproximityprompt(prompt, 0) end)
                prompt.HoldDuration = oldHold
                task.wait(0.1)
            end
        end
    end
end

