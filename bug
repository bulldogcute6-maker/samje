local function findFirePromptsInShop(shop)
    local prompts = {}
    local pcs = shop:FindFirstChild("PCS")
    if not pcs then return prompts end
    
    for _, pcModel in ipairs(pcs:GetChildren()) do
        if not pcModel:IsA("Model") or not tonumber(pcModel.Name) then continue end
        local desktop = pcModel:FindFirstChild("Desktop")
        if not desktop then continue end
        
        for _, desc in ipairs(desktop:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled then
                local isFirePrompt = false
                if desc.Name == "ExtinguishPrompt" then
                    isFirePrompt = true
                elseif desc.Parent and desc.Parent.Name == "FireEffects" then
                    isFirePrompt = true
                end
                if isFirePrompt then
                    table.insert(prompts, desc)
                end
            end
        end
    end
    return prompts
end

local function extinguishFires(shop)
    if not shop then return 0 end
    local prompts = findFirePromptsInShop(shop)
    if #prompts == 0 then return 0 end
    
    if not equipFireExtinguisher() then
        Library:Notify({ Title = "Fire Extinguish", Description = "Fire Extinguisher not found in inventory.", Duration = 2 })
        return 0
    end
    
    local extinguished = 0
    for _, prompt in ipairs(prompts) do
        if prompt.Enabled then
            local holdDur = prompt.HoldDuration or 2
            local ok = pcall(function() fireproximityprompt(prompt, holdDur) end)
            if ok then
                extinguished = extinguished + 1
                task.wait(0.1)
            end
        end
    end
    return extinguished
end

local function doFireExtinguish()
    local shop = getPlayerShop()
    if not shop then 
        Library:Notify({ Title = "Fire Extinguish", Description = "Not inside your Shop.", Duration = 2 })
        return 
    end
    local count = extinguishFires(shop)
    if count > 0 then
        Library:Notify({ Title = "Fire Extinguish", Description = "Extinguished " .. count .. " fire(s).", Duration = 3 })
    else
        Library:Notify({ Title = "Fire Extinguish", Description = "No fires detected.", Duration = 2 })
    end
end

