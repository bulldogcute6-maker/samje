local function getPcList()
    local mainUi = LP.PlayerGui:FindFirstChild("MainUi")
    if not mainUi then return nil end
    local serverFrame = mainUi:FindFirstChild("ServerFrame")
    if not serverFrame then return nil end
    return serverFrame:FindFirstChild("PcList")
end

local function getAvailablePCSlots()
    local slots = {}
    local pcList = getPcList()
    if not pcList then return slots end
    
    for _, child in ipairs(pcList:GetChildren()) do
        if child:IsA("Frame") and child.Name:match("^Pc%d+$") then
            local appointFrame = child:FindFirstChild("AppointFrame")
            if appointFrame then
                local buttonFrame = appointFrame:FindFirstChild("ButtonFrame")
                if buttonFrame then
                    local button = buttonFrame:FindFirstChild("Button")
                    if button and button:IsA("TextButton") and button.Visible then
                        local rejectFrame = child:FindFirstChild("RejectFrame")
                        if not rejectFrame or not rejectFrame.Visible then
                            table.insert(slots, child.Name)
                        end
                    end
                end
            end
        end
    end
    table.sort(slots, function(a,b)
        local numA = tonumber(a:match("%d+")) or 0
        local numB = tonumber(b:match("%d+")) or 0
        return numA < numB
    end)
    return slots
end

local function doAppoint()
    if not selectPCRemote or not appointNPCRemote then
        Library:Notify({ Title = "Appoint Error", Description = "Remotes missing.", Duration = 3 })
        return false
    end
    local slots = getAvailablePCSlots()
    if #slots == 0 then
        Library:Notify({ Title = "Appoint Error", Description = "No available PC slots found", Duration = 3 })
        return false
    end
    local slot = slots[1]
    pcall(function() selectPCRemote:FireServer(slot) end)
    task.wait(0.2)
    pcall(function() appointNPCRemote:FireServer() end)
    Library:Notify({ Title = "Appoint", Description = string.format("Appointed to %s", slot), Duration = 2 })
    return true
end

local function rejectCurrentNPC()
    if rejectNPCRemote then
        pcall(function() rejectNPCRemote:FireServer() end)
        Library:Notify({ Title = "Reject", Description = "Rejected current NPC", Duration = 2 })
    end
end

local function getCurrentNPCFromUI()
    local mainUi = LP.PlayerGui:FindFirstChild("MainUi")
    if not mainUi then return nil end
    local serverFrame = mainUi:FindFirstChild("ServerFrame")
    if not serverFrame then return nil end
    local npcInfo = serverFrame:FindFirstChild("NpcInfo")
    if not npcInfo then return nil end
    
    local function findNPCName(parent)
        for _, child in ipairs(parent:GetChildren()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") then
                local text = child.Text
                if text and #text > 0 and text ~= "Appoint Here" and text ~= "Reject" and text ~= "X" and text ~= "Close" then
                    return text
                end
            elseif child:IsA("Frame") or child:IsA("ScrollingFrame") then
                local found = findNPCName(child)
                if found then return found end
            end
        end
        return nil
    end
    return findNPCName(npcInfo)
end

local function processNPC(frame)
    if not frame or not frame:IsA("Frame") then return end
    if not autoAppointEnabled then return end
    local appointFrame = frame:FindFirstChild("AppointFrame")
    if not appointFrame or not appointFrame.Visible then return end
    local name = frame.Name
    pcall(function()
        selectPCRemote:FireServer(name)
        task.wait(0.1)
        appointNPCRemote:FireServer()
    end)
end

local function startAutoAppoint()
    if autoAppointEnabled then return end
    autoAppointEnabled = true
    local pcList = getPcList()
    if not pcList then
        Library:Notify({ Title = "Auto-Appoint", Description = "PcList not found.", Duration = 3 })
        return
    end
    for _, child in ipairs(pcList:GetChildren()) do
        processNPC(child)
    end
    table.insert(autoAppointConnections, pcList.ChildAdded:Connect(function(child)
        processNPC(child)
    end))
    Library:Notify({ Title = "Auto-Appoint", Description = "Active. Waiting for NPCs...", Duration = 2 })
end

local function stopAutoAppoint()
    autoAppointEnabled = false
    for _, conn in ipairs(autoAppointConnections) do
        pcall(conn.Disconnect, conn)
    end
    autoAppointConnections = {}
    Library:Notify({ Title = "Auto-Appoint", Description = "Stopped.", Duration = 2 })
end

local function formatMerchantTime(seconds)
    seconds = math.max(0, math.floor(seconds))
    return string.format("%d:%02d", math.floor(seconds / 60), seconds % 60)
end

local function openMerchant()
    if MerchantOpen then pcall(function() MerchantOpen:FireServer() end) end
end

local function refreshMerchant()
    if MerchantRequest and merchantState.Token then
        pcall(function() MerchantRequest:FireServer("Refresh", merchantState.Token, merchantState.Revision, merchantState.CycleId) end)
    elseif MerchantRequest then
        pcall(function() MerchantRequest:FireServer() end)
    end
end

local function buyMerchantItem(itemId)
    if merchantState.Token and not merchantState.BuyLock then
        merchantState.BuyLock = true
        pcall(function() MerchantRequest:FireServer("Purchase", merchantState.Token, merchantState.Revision, merchantState.CycleId, itemId) end)
        task.wait(0.5)
        merchantState.BuyLock = false
    end
end

local function saveConfig()
    local data = {
        autoCleanEnabled = autoCleanEnabled,
        autoFireExtinguishEnabled = autoFireExtinguishEnabled,
        antiAfkEnabled = antiAfkEnabled,
        merchantAutoBuyItems = merchantState.AutoBuyItems,
        merchantAutoBuyEnabled = merchantState.AutoBuyEnabled,
    }
    pcall(function() writefile(configFileName, HttpService:JSONEncode(data)) end)
end

local function toggleMerchantAutoBuy(itemId)
    if merchantState.AutoBuyItems[itemId] then
        merchantState.AutoBuyItems[itemId] = nil
    else
        merchantState.AutoBuyItems[itemId] = true
    end
    saveConfig()
    return merchantState.AutoBuyItems[itemId] == true
end

local function isMerchantAutoBuy(itemId)
    return merchantState.AutoBuyItems[itemId] == true
end

local function startMerchantAutoBuy()
    if merchantState.AutoBuyLoop then task.cancel(merchantState.AutoBuyLoop) end
    merchantState.AutoBuyLoop = task.spawn(function()
        while merchantState.AutoBuyEnabled do
            if merchantState.Visible and #merchantState.Offers > 0 then
                for _, offer in ipairs(merchantState.Offers) do
                    if merchantState.AutoBuyItems[offer.Id] and offer.Stock and offer.Stock > 0 then
                        buyMerchantItem(offer.Id)
                        task.wait(0.3)
                    end
                end
            end
            task.wait(2)
        end
    end)
end

local function stopMerchantAutoBuy()
    if merchantState.AutoBuyLoop then task.cancel(merchantState.AutoBuyLoop); merchantState.AutoBuyLoop = nil end
end

local function applyMerchantData(data, isInitial)
    if type(data) ~= "table" then return end
    if data.Close == true then
        merchantState.Visible = false
        merchantState.Token = nil
        if merchantState.AutoBuyEnabled then
            Library:Notify({ Title = "Merchant", Description = "Merchant closed", Duration = 2 })
        end
        return
    end
    if type(data.Token) == "string" and type(data.Revision) == "number" and type(data.CycleId) == "number" and type(data.Offers) == "table" then
        if not isInitial and merchantState.Token and data.Token ~= merchantState.Token then return end
        merchantState.Token = data.Token
        merchantState.Revision = data.Revision
        merchantState.CycleId = data.CycleId
        merchantState.ActiveEndsAt = type(data.ActiveEndsAt) == "number" and data.ActiveEndsAt or 0
        merchantState.NextArrivalAt = type(data.NextArrivalAt) == "number" and data.NextArrivalAt or 0
        merchantState.Visible = true
        merchantState.Offers = data.Offers
        if data.Message and data.Message ~= "" then
            Library:Notify({ Title = "Merchant", Description = data.Message, Duration = 3 })
        end
    end
end

MerchantOpen.OnClientEvent:Connect(function(data) applyMerchantData(data, true) end)
MerchantUpdate.OnClientEvent:Connect(function(data) applyMerchantData(data, false) end)
MerchantNotice.OnClientEvent:Connect(function(message)
    if message and message ~= "" then
        Library:Notify({ Title = "Merchant", Description = message, Duration = 3 })
    end
end)

local function loadConfig()
    local ok, content = pcall(function() return readfile(configFileName) end)
    if ok and content then
        local data = HttpService:JSONDecode(content)
        if data then
            autoCleanEnabled = data.autoCleanEnabled or false
            autoFireExtinguishEnabled = data.autoFireExtinguishEnabled or false
            antiAfkEnabled = data.antiAfkEnabled or false
            merchantState.AutoBuyItems = data.merchantAutoBuyItems or {}
            merchantState.AutoBuyEnabled = data.merchantAutoBuyEnabled or false
        end
    end
end
